{
    "latex-workshop.latex.tools": [
      {
        "name": "pdflatex",
        "command": "pdflatex",
        "args": [
          "-shell-escape",
          "-interaction=nonstopmode",
          "-synctex=1",
          "%DOC%"
        ]
      },
      {
        "name": "latexmk",
        "command": "latexmk",
        "args": [
          "-shell-escape",
          "-synctex=1",
          "-interaction=nonstopmode",
          "-file-line-error",
          "-pdf",
          "%DOC%"
        ]
      }
    ],
    "latex-workshop.latex.recipes": [
      {
        "name": "latexmk (shell-escape)",
        "tools": ["latexmk"]
      },
      {
        "name": "pdflatex (shell-escape)",
        "tools": ["pdflatex"]
      }
    ]
  }
  